{
  "name": "ha-lindenweg-dashboard",
  "version": "0.2.6",
  "description": "Skandinavisch / Muji-inspiriertes Home Assistant Custom Panel — Räume, Szenen, Energie, Wetter — voll grafisch konfigurierbar",
  "type": "module",
  "main": "dist/lindenweg-dashboard.js",
  "scripts": {
    "build": "vite build && mkdir -p custom_components/lindenweg_dashboard/frontend && cp dist/lindenweg-dashboard.js custom_components/lindenweg_dashboard/frontend/lindenweg-dashboard.js",
    "watch": "vite build --watch",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": ["home-assistant", "lovelace", "hacs", "panel", "dashboard", "skandinavisch"],
  "author": "Christian Brinkmann",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "@types/node": "^20.11.0"
  },
  "dependencies": {
    "lit": "^3.1.0",
    "custom-card-helpers": "^1.9.0"
  }
}
